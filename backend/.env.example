APP_NAME=Jons Gradebook API
ENV=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ENCRYPTION_KEY=change-this-with-a-32-byte-base64-fernet-key
DATABASE_URL=postgresql+psycopg://gradebook:gradebook@db:5432/gradebook
CANVAS_BASE_URL=https://canvas.example.edu
CANVAS_API_TOKEN=replace-me
CANVAS_ACCOUNT_ID=1
OPENAI_API_KEY=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://ollama:11434
DEFAULT_TIMEZONE=America/Chicago
DAILY_SYNC_CRON=0 5 * * *
STORAGE_ROOT=/data/storage
BACKUP_ROOT=/data/backups
CORS_ORIGINS=http://localhost:5173,http://localhost:4173
LLM_DEIDENTIFY_DEFAULT=true
